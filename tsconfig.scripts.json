{
  "compilerOptions": {
    "target": "ESNext",
    "module": "commonjs",
    "lib": ["ESNext"],

    "rootDir": "scripts",
    "outDir": "build-scripts",

    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "noEmitOnError": true
  },
  "include": ["scripts/**/*.ts", "scripts/**/*.d.ts"],
  "exclude": ["build-scripts", "node_modules"]
}